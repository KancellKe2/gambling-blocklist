# OmniRoute Configuration
OMNIROUTE_API_KEY=your_omniroute_api_key_here
OMNIROUTE_ENDPOINT=https://api.omniroute.com/v1

# Firecrawl Configuration (optional)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_ENDPOINT=https://api.firecrawl.dev/v1

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# KV Namespace IDs (from wrangler kv:namespace create)
BLOCKLIST_KV_ID=your_kv_namespace_id_here
BLOCKLIST_KV_ID_PRODUCTION=your_production_kv_namespace_id_here

# R2 Bucket Name
R2_BUCKET_NAME=gambling-blocklist-data

# Environment
ENVIRONMENT=development

# GitHub Configuration (for automatic repo creation)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_username_here

# Crawler Configuration
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30000
RATE_LIMIT_DELAY=1000
USER_AGENT=GamblingBlocklistBot/1.0

# AI Configuration
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=1000

# Scoring Configuration
MIN_CONFIDENCE_THRESHOLD=0.7
HIGH_CONFIDENCE_THRESHOLD=0.9

# Blocklist Configuration
BLOCKLIST_FORMAT=adguard
UPDATE_INTERVAL_HOURS=6
MAX_DOMAINS_PER_UPDATE=10000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/gambling-blocklist.log